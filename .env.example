# ============================================
# Core Runtime (Required)
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Required: Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ============================================
# Secrets Management
# ============================================
# Required: active provider for runtime secret reads (render|aws|local)
SECRET_PROVIDER=render
# Optional: in-memory secret cache TTL for SecretsService
SECRETS_CACHE_TTL_MS=60000

# ============================================
# Database Pool (Optional)
# ============================================
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
DB_POOL_QUERY_TIMEOUT_MS=15000
DB_QUERY_RETRY_ATTEMPTS=3
DB_QUERY_RETRY_BACKOFF_MS=200

# ============================================
# Backup / Disaster Recovery (Optional)
# ============================================
BACKUP_DIRECTORY=.backups

# ============================================
# Redis (Optional)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Authentication (Recommended in all environments)
# ============================================
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ============================================
# Encryption / Token Security (Required in production)
# ============================================
ENCRYPTION_SECRET=replace_with_strong_random_secret
# Legacy key still read by some integrations
ENCRYPTION_KEY=replace_with_legacy_key_if_needed

# ============================================
# AWS S3 Storage (Optional)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=xclsv-core-platform

# ============================================
# OAuth Integrations (Optional unless integration enabled)
# ============================================
APP_URL=http://localhost:3001
QUICKBOOKS_CLIENT_ID=quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=quickbooks_client_secret
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REALM_ID=1234567890

RAMP_CLIENT_ID=ramp_client_id
RAMP_CLIENT_SECRET=ramp_client_secret

# ============================================
# External API Integrations (Optional)
# ============================================
CUSTOMERIO_SITE_ID=customerio_site_id
CUSTOMERIO_API_KEY=customerio_api_key
AI_VISION_API_URL=https://api.example.com/vision
AI_VISION_API_KEY=vision_api_key

# ============================================
# App Settings
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
LOG_LEVEL=debug
